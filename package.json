{
  "name": "pi-antigravity",
  "version": "0.2.3",
  "description": "Personal Antigravity / Cloud Code Assist provider for Pi Coding Agent",
  "author": "Rahul Arya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rahularya01/pi-antigravity.git"
  },
  "homepage": "https://github.com/Rahularya01/pi-antigravity#readme",
  "bugs": {
    "url": "https://github.com/Rahularya01/pi-antigravity/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "keywords": [
    "pi-package",
    "pi-extension",
    "antigravity",
    "google",
    "oauth",
    "provider"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security-check": "tsx scripts/security-check.ts",
    "test": "tsx scripts/test-model-routing.ts",
    "smoke:tools": "tsx scripts/smoke-tool-schema.ts",
    "smoke:models": "node --import tsx scripts/smoke-all-models.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run security-check && npm test"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.0",
    "@earendil-works/pi-coding-agent": ">=0.80.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  }
}
